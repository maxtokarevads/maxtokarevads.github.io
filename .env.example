# Claude API — required for the agent to work
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Current valid model IDs (June 2026):
#   claude-opus-4-8           — most capable, higher cost
#   claude-sonnet-4-6         — balanced (recommended default)
#   claude-haiku-4-5-20251001 — fastest, lowest cost
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_STREAM=true

# Analyzer backend: "api" (HTTP API, requires key) or "claude_code" (Pro/Max subscription)
ANALYZER_BACKEND=api

# Telegram bot settings
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_POLLING_TIMEOUT=30
TELEGRAM_DEFAULT_AGENT=ads

# Bot access control — REQUIRED for production.
# Comma-separated Telegram user IDs allowed to use the bot.
# Get your ID: message @userinfobot on Telegram.
# WARNING: leaving this empty opens the bot to anyone (costs your API budget).
ALLOWED_CHAT_IDS=123456789,987654321

# SQLite database path for persistent chat state
DB_PATH=bot_state.db

# ── Google Ads API integration ──────────────────────────────────────────────
# Run setup_google_ads_oauth.py to fill these automatically.
# GOOGLE_ADS_DEVELOPER_TOKEN — from Google Ads → Admin → API Center
# GOOGLE_ADS_CLIENT_ID, CLIENT_SECRET — from Google Cloud Console → Credentials
# GOOGLE_ADS_REFRESH_TOKEN — generated by setup_google_ads_oauth.py
# GOOGLE_ADS_CUSTOMER_ID — your 10-digit account ID (no dashes)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ── Meta (Facebook) Ads API integration ─────────────────────────────────────
# 1. Create a Meta App at developers.facebook.com
# 2. Add Marketing API product, request ads_read + ads_management permissions
# 3. Generate a long-lived system user access token in Meta Business Manager
# 4. META_ACCOUNT_ID — find in Meta Ads Manager URL: act_XXXXXXXXXX
META_ACCESS_TOKEN=
META_ACCOUNT_ID=

# ── TikTok Ads API integration ───────────────────────────────────────────────
# 1. Apply for TikTok Marketing API at business.tiktok.com/portal
# 2. Create an app and request REPORTING + CAMPAIGN_MANAGEMENT scopes
# 3. Generate an access token (long-lived via OAuth or system app token)
# 4. TIKTOK_ADVERTISER_ID — find in TikTok Ads Manager → Account Info
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# ── SEO integrations ─────────────────────────────────────────────────────────
# Google Search Console — service account JSON (file path or inline JSON string)
GSC_CREDENTIALS_FILE=gsc_token.json
# PageSpeed Insights API key — from Google Cloud Console
PAGESPEED_API_KEY=
# Skip live enrichment in tests (set to true in CI)
SEO_SKIP_ENRICHMENT=false

# ── Web dashboard ────────────────────────────────────────────────────────────
DASHBOARD_PORT=5000
